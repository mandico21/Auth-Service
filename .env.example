# Application
API__HOST=0.0.0.0
API__PORT=8000
API__WORKERS=1
API__DEBUG=true
API__INSTANCE_APP_NAME=pattern-service
API__REQUEST_TIMEOUT=30
# Graceful shutdown: max seconds to close connectors; use gunicorn --graceful-timeout >= this
API__GRACEFUL_SHUTDOWN_TIMEOUT=30

# PostgreSQL (MIN/MAX are per worker; total connections = API__WORKERS * MAX_CONNECTION)
POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__USER=postgres
POSTGRES__PASSWORD=postgres
POSTGRES__DATABASE_NAME=pattern_service
POSTGRES__MIN_CONNECTION=2
POSTGRES__MAX_CONNECTION=20
POSTGRES__MAX_IDLE=300
POSTGRES__TIMEOUT=30
POSTGRES__STATEMENT_TIMEOUT=30000
# POSTGRES__DSN=postgresql://postgres:postgres@localhost:5432/pattern_service

# Redis (optional; set REDIS__ENABLED=true to use). Path segment = logical DB index (0–15): /0, /1, …
REDIS__ENABLED=false
REDIS__URL=redis://localhost:6379/0
REDIS__SOCKET_TIMEOUT=5.0
REDIS__SOCKET_CONNECT_TIMEOUT=5.0
REDIS__MAX_CONNECTIONS=10
REDIS__DECODE_RESPONSES=true
